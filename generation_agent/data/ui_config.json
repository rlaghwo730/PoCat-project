{
  "steps": [
    {
      "step": 1,
      "title": "상품 정보",
      "fields": [
        {
          "key": "product_name",
          "label": "상품명",
          "type": "text",
          "default": "무배당 삼성화재 실손의료비보험"
        },
        {
          "key": "product_version",
          "label": "버전",
          "type": "text",
          "default": "2601.6"
        }
      ]
    },
    {
      "step": 2,
      "title": "상품 설계 조건",
      "fields": [
        {
          "key": "policy_period",
          "label": "보험기간",
          "type": "fixed",
          "fixed_value": "1년",
          "fixed_reason": "실손보험 표준"
        },
        {
          "key": "premium_payment_period",
          "label": "납입기간",
          "type": "fixed",
          "fixed_value": "전기납",
          "fixed_reason": "실손보험 표준"
        },
        {
          "key": "renewal_type",
          "label": "갱신유형",
          "type": "dropdown",
          "options": ["갱신형", "비갱신형"],
          "default": "갱신형"
        },
        {
          "key": "renewal_period",
          "label": "갱신주기",
          "type": "number",
          "unit": "년",
          "min": 1,
          "max": 5,
          "default": 1
        },
        {
          "key": "max_coverage_age",
          "label": "최대보장나이",
          "type": "number",
          "unit": "세",
          "min": 60,
          "max": 110,
          "default": 100
        },
        {
          "key": "join_age_range",
          "label": "가입연령",
          "type": "fixed",
          "fixed_value": "0세~65세",
          "fixed_reason": "삼성화재 기준"
        }
      ]
    },
    {
      "step": 3,
      "title": "보장 조건",
      "fields": [
        {
          "key": "basic_coverage_items",
          "label": "기본 보장종목",
          "type": "multiselect",
          "options": ["급여 상해", "급여 질병"],
          "default": ["급여 상해", "급여 질병"]
        },
        {
          "key": "noncovered_rider_items",
          "label": "비급여 특약종목",
          "type": "multiselect",
          "options": ["비급여 상해", "비급여 질병", "3대 비급여"],
          "default": ["비급여 상해", "비급여 질병", "3대 비급여"]
        },
        {
          "key": "three_major_noncovered_items",
          "label": "3대 비급여 세부항목",
          "type": "multiselect",
          "options": ["도수치료·체외충격파·증식치료", "주사료", "자기공명영상진단"],
          "default": ["도수치료·체외충격파·증식치료", "주사료", "자기공명영상진단"]
        },
        {
          "key": "coverage_limit",
          "label": "보장한도",
          "type": "fixed",
          "fixed_value": "5천만원",
          "fixed_reason": "삼성화재 기준"
        },
        {
          "key": "deductible_rule",
          "label": "자기부담금",
          "type": "fixed",
          "fixed_value": "급여 20%, 비급여 30%",
          "fixed_reason": "실손보험 표준"
        }
      ]
    },
    {
      "step": 4,
      "title": "가입자 정보",
      "fields": [
        {
          "key": "applicant_type",
          "label": "가입자 유형",
          "type": "dropdown",
          "options": ["본인", "미성년 자녀", "태아"],
          "default": "본인"
        },
        {
          "key": "birth_date",
          "label": "생년월일",
          "type": "date",
          "min": "1900-01-01",
          "default": "1990-01-01"
        },
        {
          "key": "gender",
          "label": "성별",
          "type": "radio",
          "options": ["남성", "여성"],
          "default": "남성"
        },
        {
          "key": "occupation",
          "label": "직업",
          "type": "text",
          "default": "회사원"
        }
      ]
    }
  ]
}
