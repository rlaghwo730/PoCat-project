# 실손보험 법령·규제 데이터 파이프라인 환경변수 예시
# 실제 실행 시 이 파일을 복사하여 .env 파일로 사용합니다.
# 실제 API Key는 GitHub, Notion, ZIP 공유본에 포함하지 않습니다.

# 1. 국가법령정보 API 설정

LAW_API_KEY=YOUR_LAW_API_KEY_HERE
LAW_API_BASE_URL=https://www.law.go.kr/DRF


# 2. PostgreSQL DB 설정

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=silson_legal_db
POSTGRES_USER=silson
POSTGRES_PASSWORD=silson_pw

DATABASE_URL=postgresql+psycopg2://silson:silson_pw@localhost:5433/silson_legal_db


# 3. 파일 경로 설정

LEGAL_INVENTORY_PATH=data/input/legal_inventory.xlsx
EXTERNAL_DOCS_DIR=data/external
LEGAL_BODY_OUTPUT_DIR=data/output/legal_body
CHROMA_PERSIST_DIR=data/vector_store/chroma


# 4. Vector DB / Embedding 설정

EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

CHROMA_COLLECTION_LAW=law_regulation_vectors
CHROMA_COLLECTION_ATTACHMENT=law_attachment_vectors
CHROMA_COLLECTION_EXTERNAL=external_reference_vectors


# 5. Airflow 설정 예시

AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin


# 6. 실행 옵션

APP_ENV=local
LOG_LEVEL=INFO
